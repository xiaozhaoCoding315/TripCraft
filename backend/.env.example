# TripCraft Backend 环境配置
# 复制此文件为 .env 并修改实际值

# ========== 应用配置 ==========
APP_NAME=TripCraft API
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== JWT 密钥（生产环境必须修改！） ==========
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-32-char-minimum-secret-key-change-me

# ========== PostgreSQL 配置 ==========
POSTGRES_HOST=192.168.150.128
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tripcraft

# ========== Redis 配置 ==========
REDIS_ENABLED=true
REDIS_URL=redis://:159753852@192.168.150.128:6379/0

# ========== Qwen / DashScope ==========
DASHSCOPE_API_KEY=your-dashscope-api-key
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_EMBEDDING_DIMENSION=1024

# ========== Qdrant ==========
QDRANT_URL=http://192.168.150.128:6333
QDRANT_API_KEY=
QDRANT_TRAVEL_NOTES_COLLECTION=travel_notes
QDRANT_ATTRACTIONS_COLLECTION=attractions

# ========== 高德地图 ==========
AMAP_API_KEY=your-amap-api-key
AMAP_WEB_JS_KEY=your-amap-web-js-key

# ========== 其他 ==========
TOKEN_EXPIRE_HOURS=24
MAX_CRITIC_ROUNDS=3
